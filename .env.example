# ====================================
# Sufra Cloud - Environment Variables
# ====================================

# Gemini AI API Key
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL
APP_URL="http://localhost:3000"

# ====================================
# PostgreSQL Database
# ====================================
# الخيار 1: رابط كامل (موصى به للإنتاج)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sufra_cloud

# الخيار 2: متغيرات منفصلة (للتطوير المحلي)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sufra_cloud
